          "E-Mail": "dieter.wissmann@hs-coburg.de",
          "Büro": "2-127"
        }
      }
    ],
    "settings": {
      "lemosVersion": "1.0.0",
      "showFieldIDs": true,
      "differentStepSizes": false
    }
  },
  "fields": [
    {
      "id": "T",
      "name": "Aufgabentyp",
      "explanation": "Auswahl, welche Variante der Formel genutzt werden soll (nicht implementiert)",
      "type": "SELECT",
      "options": [
        {
          "id": "Auto",
          "name": "Automatisch",
          "explanation": "Berechnung des leer gelassenen Felds"
        },
        {
          "id": "Fall1",
          "name": "Länge gesucht",
          "explanation": "Y und W gegeben, N gesucht"
        },
        {
          "id": "Fall2",
          "name": "Ankunftsrate gesucht",
          "explanation": "N und W gegeben, Y gesucht"
        },
        {
          "id": "Fall3",
          "name": "Wartezeit gesucht",
          "explanation": "N und Y gegeben, W gesucht"
        }
      ]
    },
    {
      "id": "N",
      "name": "Länge",
      "explanation": "Durchschnittliche Länge der Warteschlange",
      "type": "TEXT",
      "usage": "INPUT",
      "allowEmpty": true,
      "datatype": "NUMBER",
      "restrictions": [
        {
          "message": "Nur positive Zahlenwerte",
          "terms": [
            "N >= 0"
          ]
        }
      ]
    },
    {
      "id": "Y",
      "name": "Ankunftsrate",
      "explanation": "Durchschnittliche Ankunftsrate neuer Einträge",
      "type": "TEXT",
      "usage": "INPUT",
      "allowEmpty": true,
      "datatype": "NUMBER",
      "restrictions": [
        {
          "message": "Nur positive Zahlenwerte",
          "terms": [
            "Y >= 0"
          ]
        }
      ]
    },
    {
      "id": "W",
      "name": "Wartezeit",
      "explanation": "Durchschnittliche Wartezeit eines Eintrags",
      "type": "TEXT",
      "usage": "INPUT",
      "allowEmpty": true,
      "datatype": "NUMBER",
      "restrictions": [
        {
          "message": "Nur positive Zahlenwerte",
          "terms": [
            "W >= 0"
          ]
        }
      ]
    }
  ],
  "states": [
    {
      "id": "Z0",
      "name": "Lernmodul initialisiert",
      "explanation": "Einstieg",
      "type": "ENTRY",
      "actions": [],
      "transitions": [
        {
          "target": "Z1",
          "name": "B1",
          "explanation": "Übergang zur Fallunterscheidung",
          "conditions": [
            {
              "message": "",
              "terms": [
                "Fields.countFilled() === 3"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "Z1",
      "name": "Welche Felder?",
      "explanation": "Fallunterscheidung",
      "type": "JUNCTION",
      "transitions": [
        {
          "target": "Z1a",
          "name": "B1a",
          "explanation": "Übergang zu Fall 1",
          "conditions": [
            {
              "message": "",
              "terms": [
                "Fields.areFilled(Y, W)"
              ]
            }
          ]
        },
        {
          "target": "Z1b",
          "name": "B1b",
          "explanation": "Übergang zu Fall 2",
          "conditions": [
            {
              "message": "",
              "terms": [
                "Fields.areFilled(N, W)"
              ]
            }
          ]
        },
        {
          "target": "Z1c",
          "name": "B1c",
          "explanation": "Übergang zu Fall 3",
          "conditions": [
            {
              "message": "",
              "terms": [
                "Fields.areFilled(N, Y)"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "Z1a",
      "name": "N berechnet",
      "explanation": "Fall 1: Y und W gegeben, N gesucht",
      "type": "STATE",
      "importance": "HIGH",
      "actions": [
        "N.setValue(Y * W)"
      ],
      "transitions": []
    },
    {
      "id": "Z1b",
      "name": "Y berechnet",
      "explanation": "Fall 2: N und W gegeben, Y gesucht",
      "type": "STATE",
      "importance": "HIGH",
      "actions": [
        "Y.setValue(N / W)"
      ],
      "transitions": []
    },
    {
      "id": "Z1c",
      "name": "W berechnet",
      "explanation": "Fall 3: N und Y gegeben, W gesucht",
      "type": "STATE",
      "importance": "HIGH",
      "actions": [
        "W.setValue(N / Y)"
      ],
      "transitions": []
    }
  ]
}