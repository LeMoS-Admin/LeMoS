{
  "$schema": "../LeMoS-Modul-Schema.json",
  "general": {
    "heading": "Theorem von Little",
    "explanation": "Nutzen Sie das Lernmodul, um die Formel des Theorems von Little anzuwenden.",
    "sources": [
      "Skript von Herr Professor Wißmann",
      "Internet"
    ],
    "contacts": [
      {
        "name": "Professor Dr. Dieter Wißmann",
