<?xml version="1.0" encoding="UTF-8"?>
<module>
    <general>
        <heading>Theorem von Little</heading>
        <explanation>Nutzen Sie das Lernmodul, um die Formel des Theorems von Little anzuwenden.</explanation>
        <sources>
            <source>Skript von Herr Professor Wißmann</source>
            <source>Internet</source>
        </sources>
        <contacts>
            <contact>
                <name>Professor Dr. Dieter Wißmann</name>
                <purpose>Fachliche Fragen</purpose>
                <data>
                    <Telefon>09561 317-152</Telefon>
                    <E-Mail>dieter.wissmann@hs-coburg.de</E-Mail>
                    <Büro>2-127</Büro>
                </data>
            </contact>
            <contact>
                <name>Professor Dr. Dieter Wißmann</name>
                <purpose>Technische Fragen</purpose>
                <data>
                    <Telefon>09561 317-152</Telefon>
                    <E-Mail>dieter.wissmann@hs-coburg.de</E-Mail>
                    <Büro>2-127</Büro>
                </data>
            </contact>
        </contacts>
        <settings>
            <lemosVersion>1.0.0</lemosVersion>
            <showFieldIDs>true</showFieldIDs>
            <differentStepSizes>false</differentStepSizes>
        </settings>
    </general>
    <fields>
        <field>
            <id>T</id>
            <name>Aufgabentyp</name>
            <explanation>Auswahl, welche Variante der Formel genutzt werden soll (nicht implementiert)</explanation>
            <type>SELECT</type>
            <options>
                <option>
                    <id>Auto</id>
                    <name>Automatisch</name>
                    <explanation>Berechnung des leer gelassenen Felds</explanation>
                </option>
                <option>
                    <id>Fall1</id>
                    <name>Länge gesucht</name>
                    <explanation>Y und W gegeben, N gesucht</explanation>
                </option>
                <option>
                    <id>Fall2</id>
                    <name>Ankunftsrate gesucht</name>
                    <explanation>N und W gegeben, Y gesucht</explanation>
                </option>
                <option>
                    <id>Fall3</id>
                    <name>Wartezeit gesucht</name>
                    <explanation>N und Y gegeben, W gesucht</explanation>
                </option>
            </options>
        </field>
        <field>
            <id>N</id>
            <name>Länge</name>
            <explanation>Durchschnittliche Länge der Warteschlange</explanation>
            <type>TEXT</type>
            <usage>INPUT</usage>
            <allowEmpty>true</allowEmpty>
            <datatype>NUMBER</datatype>
            <restrictions>
                <restriction>
                    <message>Nur positive Zahlenwerte</message>
                    <terms>
                        <operation>Number.isNaN(N.value) || N &gt;= 0</operation>
                    </terms>
                </restriction>
            </restrictions>
        </field>
        <field>
            <id>Y</id>
            <name>Ankunftsrate</name>
            <explanation>Durchschnittliche Ankunftsrate neuer Einträge</explanation>
            <type>TEXT</type>
            <usage>INPUT</usage>
            <allowEmpty>true</allowEmpty>
            <datatype>NUMBER</datatype>
            <restrictions>
                <restriction>
                    <message>Nur positive Zahlenwerte</message>
                    <terms>
                        <operation>Number.isNaN(Y.value) || Y &gt;= 0</operation>
                    </terms>
                </restriction>
            </restrictions>
        </field>
        <field>
            <id>W</id>
            <name>Wartezeit</name>
            <explanation>Durchschnittliche Wartezeit eines Eintrags</explanation>
            <type>TEXT</type>
            <usage>INPUT</usage>
            <allowEmpty>true</allowEmpty>
            <datatype>NUMBER</datatype>
            <restrictions>
                <restriction>
                    <message>Nur positive Zahlenwerte</message>
                    <terms>
                        <operation>Number.isNaN(W.value) || W &gt;= 0</operation>
                    </terms>
                </restriction>
            </restrictions>
        </field>
    </fields>
    <states>
        <state>
            <id>Z0</id>
            <name>Lernmodul initialisiert</name>
            <explanation>Einstieg</explanation>
            <type>ENTRY</type>
            <!--Keine
            Aktion-->
            <transitions>
                <transition>
                    <target>Z1</target>
                    <name>B1</name>
                    <explanation>Übergang zur Fallunterscheidung</explanation>
                    <conditions>
                        <condition>
                            <terms>
                                <operation>Fields.countFilled() === 3</operation>
                            </terms>
                        </condition>
                    </conditions>
                </transition>
            </transitions>
        </state>
        <state>
            <id>Z1</id>
            <name>Welche Felder?</name>
            <explanation>Fallunterscheidung</explanation>
            <type>JUNCTION</type>
            <transitions>
                <transition>
                    <target>Z1a</target>
                    <name>B1a</name>
                    <explanation>Übergang zu Fall 1</explanation>
                    <conditions>
                        <condition>
                            <terms>
                                <operation>Fields.areFilled(Y, W)</operation>
                            </terms>
                        </condition>
                    </conditions>
                </transition>
                <transition>
                    <target>Z1b</target>
                    <name>B1b</name>
                    <explanation>Übergang zu Fall 2</explanation>
                    <conditions>
                        <condition>
                            <terms>
                                <operation>Fields.areFilled(N, W)</operation>
                            </terms>
                        </condition>
                    </conditions>
                </transition>
                <transition>
                    <target>Z1c</target>
                    <name>B1c</name>
                    <explanation>Übergang zu Fall 3</explanation>
                    <conditions>
                        <condition>
                            <terms>
                                <operation>Fields.areFilled(N, Y)</operation>
                            </terms>
                        </condition>
                    </conditions>
                </transition>
            </transitions>
        </state>
        <state>
            <id>Z1a</id>
            <name>N berechnet</name>
            <explanation>Fall 1: Y und W gegeben, N gesucht</explanation>
            <type>STATE</type>
            <importance>HIGH</importance>
            <actions>
                <operation>N.setValue(Y * W)</operation>
            </actions>
            <!--Kein
            Übergang (Endzustand)-->
        </state>
        <state>
            <id>Z1b</id>
            <name>Y berechnet</name>
            <explanation>Fall 2: N und W gegeben, Y gesucht</explanation>
            <type>STATE</type>
            <importance>HIGH</importance>
            <actions>
                <operation>Y.setValue(N / W)</operation>
            </actions>
            <!--Kein
            Übergang (Endzustand)-->
        </state>
        <state>
            <id>Z1c</id>
            <name>W berechnet</name>
            <explanation>Fall 3: N und Y gegeben, W gesucht</explanation>
            <type>STATE</type>
            <importance>HIGH</importance>
            <actions>
                <operation>W.setValue(N / Y)</operation>
            </actions>
            <!--Kein
            Übergang (Endzustand)-->
        </state>
    </states>
</module>