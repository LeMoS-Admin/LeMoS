<?xml version="1.0" encoding="UTF-8"?>
<module>
    <general>
        <heading>Theorem von Little</heading>
        <explanation>Nutzen Sie das Lernmodul, um die Formel des Theorems von Little anzuwenden.</explanation>
        <sources>
            <source>Skript von Herr Professor Wißmann</source>
            <source>Internet</source>
        </sources>
        <contacts>
            <contact>
                <name>Professor Dr. Dieter Wißmann</name>
                <purpose>Fachliche Fragen</purpose>
                <data>
                    <Telefon>09561 317-152</Telefon>
                    <E-Mail>dieter.wissmann@hs-coburg.de</E-Mail>
                    <Büro>2-127</Büro>
                </data>
            </contact>
            <contact>
                <name>Professor Dr. Dieter Wißmann</name>
                <purpose>Technische Fragen</purpose>
                <data>
                    <Telefon>09561 317-152</Telefon>
                    <E-Mail>dieter.wissmann@hs-coburg.de</E-Mail>
                    <Büro>2-127</Büro>
                </data>
            </contact>
        </contacts>
        <config>
            <libraryVersion>1.0.0</libraryVersion>
            <showFieldIDs>true</showFieldIDs>
            <differentStepSizes>false</differentStepSizes>
        </config>
    </general>
    <fields>
        <field>
            <id>N</id>
            <name>Länge</name>
            <explanation>Durchschnittliche Länge der Warteschlange</explanation>
            <type>PLAIN</type>
            <usage>INPUT</usage>
            <datatype>NUMBER</datatype>
            <restrictions>
                <restriction>
                    <message>Nur positive Zahlenwerte</message>
                    <terms>
                        <operation>N &gt;= 0</operation>
                    </terms>
                </restriction>
            </restrictions>
            <style>
                <row>1</row>
                <column>1</column>
            </style>
        </field>
        <field>
            <id>Y</id>
            <name>Ankunftsrate</name>
            <explanation>Durchschnittliche Ankunftsrate neuer Einträge</explanation>
            <type>PLAIN</type>
            <usage>INPUT</usage>
            <datatype>NUMBER</datatype>
            <restrictions>
                <restriction>
                    <message>Nur positive Zahlenwerte</message>
                    <terms>
                        <operation>Y &gt;= 0</operation>
                    </terms>
                </restriction>
            </restrictions>
            <style>
                <row>2</row>
                <column>1</column>
            </style>
        </field>
        <field>
            <id>W</id>
            <name>Wartezeit</name>
            <explanation>Durchschnittliche Wartezeit eines Eintrags</explanation>
            <type>PLAIN</type>
            <usage>INPUT</usage>
            <datatype>NUMBER</datatype>
            <restrictions>
                <restriction>
                    <message>Nur positive Zahlenwerte</message>
                    <terms>
                        <operation>W &gt;= 0</operation>
                    </terms>
                </restriction>
            </restrictions>
            <style>
                <row>3</row>
                <column>1</column>
            </style>
        </field>
    </fields>
    <states>
        <state>
            <id>Z0</id>
            <name>Lernmodul initialisiert</name>
            <explanation>Einstieg</explanation>
            <type>ENTRY</type>
            <!--Keine
            Aktion-->
            <transitions>
                <transition>
                    <target>Z1</target>
                    <name>B1</name>
                    <explanation>Übergang zur Fallunterscheidung</explanation>
                    <conditions>
                        <condition>
                            <terms>
                                <operation>List.length(Module.filled()) === 2</operation>
                            </terms>
                        </condition>
                    </conditions>
                </transition>
            </transitions>
        </state>
        <state>
            <id>Z1</id>
            <name>Welche Felder?</name>
            <explanation>Fallunterscheidung</explanation>
            <type>JUNCTION</type>
            <transitions>
                <transition>
                    <target>Z1a</target>
                    <name>B1a</name>
                    <explanation>Übergang zu Fall 1</explanation>
                    <conditions>
                        <condition>
                            <terms>
                                <operation>Module.filled(Y, W)</operation>
                            </terms>
                        </condition>
                    </conditions>
                </transition>
                <transition>
                    <target>Z1b</target>
                    <name>B1b</name>
                    <explanation>Übergang zu Fall 2</explanation>
                    <conditions>
                        <condition>
                            <terms>
                                <operation>Module.filled(N, W)</operation>
                            </terms>
                        </condition>
                    </conditions>
                </transition>
                <transition>
                    <target>Z1c</target>
                    <name>B1c</name>
                    <explanation>Übergang zu Fall 3</explanation>
                    <conditions>
                        <condition>
                            <terms>
                                <operation>Module.filled(N, Y)</operation>
                            </terms>
                        </condition>
                    </conditions>
                </transition>
            </transitions>
        </state>
        <state>
            <id>Z1a</id>
            <name>N berechnet</name>
            <explanation>Fall 1: Y und W gegeben, N gesucht</explanation>
            <type>STATE</type>
            <importance>HIGH</importance>
            <actions>
                <operation>N.setValue(Y * W)</operation>
            </actions>
            <!--Kein
            Übergang (Endzustand)-->
        </state>
        <state>
            <id>Z1b</id>
            <name>Y berechnet</name>
            <explanation>Fall 2: N und W gegeben, Y gesucht</explanation>
            <type>STATE</type>
            <importance>HIGH</importance>
            <actions>
                <operation>Y.setValue(N / W)</operation>
            </actions>
            <!--Kein
            Übergang (Endzustand)-->
        </state>
        <state>
            <id>Z1c</id>
            <name>W berechnet</name>
            <explanation>Fall 3: N und Y gegeben, W gesucht</explanation>
            <type>STATE</type>
            <importance>HIGH</importance>
            <actions>
                <operation>W.setValue(N / Y)</operation>
            </actions>
            <!--Kein
            Übergang (Endzustand)-->
        </state>
    </states>
</module>