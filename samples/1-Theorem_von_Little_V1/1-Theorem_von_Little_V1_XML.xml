<?xml version="1.0" encoding="UTF-8"?>
<module>
    <general>
        <heading>Theorem von Little</heading>
        <explanation>Nutzen Sie das Lernmodul, um die Formel des Theorems von Little anzuwenden.</explanation>
        <sources>
            <source>Skript von Herr Professor Wißmann</source>
        </sources>
        <contact>
            <name>Professor Dr. Dieter Wißmann</name>
            <mail>dieter.wißmann@hs-coburg.de</mail>
        </contact>
        <config>
            <libraryVersion>1.0.0</libraryVersion>
            <showFieldNames>true</showFieldNames>
            <differentStepSizes>false</differentStepSizes>
        </config>
    </general>
    <fields>
        <field>
            <name>N</name>
            <description>Länge</description>
            <comment>Durchschnittliche Länge der Warteschlange</comment>
            <usage>INPUT</usage>
            <type>PLAIN</type>
            <datatype>NUMBER</datatype>
            <restrictions>
                <restriction>
                    <message>Nur positive Zahlenwerte</message>
                    <terms>
                        <operation>N &gt;= 0</operation>
                    </terms>
                </restriction>
            </restrictions>
            <size>10</size>
            <position>
                <xAxis>1</xAxis>
                <yAxis>1</yAxis>
            </position>
        </field>
        <field>
            <name>Y</name>
            <description>Ankunftsrate</description>
            <comment>Durchschnittliche Ankunftsrate neuer Einträge</comment>
            <usage>INPUT</usage>
            <type>PLAIN</type>
            <datatype>NUMBER</datatype>
            <restrictions>
                <restriction>
                    <message>Nur positive Zahlenwerte</message>
                    <terms>
                        <operation>Y &gt;= 0</operation>
                    </terms>
                </restriction>
            </restrictions>
            <size>10</size>
            <position>
                <xAxis>1</xAxis>
                <yAxis>2</yAxis>
            </position>
        </field>
        <field>
            <name>W</name>
            <description>Wartezeit</description>
            <comment>Durchschnittliche Wartezeit eines Eintrags</comment>
            <usage>INPUT</usage>
            <type>PLAIN</type>
            <datatype>NUMBER</datatype>
            <restrictions>
                <restriction>
                    <message>Nur positive Zahlenwerte</message>
                    <terms>
                        <operation>W &gt;= 0</operation>
                    </terms>
                </restriction>
            </restrictions>
            <size>10</size>
            <position>
                <xAxis>1</xAxis>
                <yAxis>3</yAxis>
            </position>
        </field>
    </fields>
    <states>
        <state>
            <name>Z0</name>
            <description>Lernmodul initialisiert</description>
            <comment>Einstieg</comment>
            <type>ENTRY_POINT</type>
            <!--Keine Aktion-->
            <transitions>
                <transition>
                    <target>Z1</target>
                    <comment>Übergang zur Fallunterscheidung</comment>
                    <condition>
                        <name>B1</name>
                        <terms>
                            <operation>List.length(Module.filled()) == 2</operation>
                        </terms>
                    </condition>
                </transition>
            </transitions>
        </state>
        <state>
            <name>Z1</name>
            <description>Welche Felder?</description>
            <comment>Fallunterscheidung</comment>
            <type>JUNCTION</type>
            <transitions>
                <transition>
                    <target>Z1a</target>
                    <comment>Übergang zu Fall 1</comment>
                    <condition>
                        <name>B1a</name>
                        <terms>
                            <operation>Module.filled(Y, W)</operation>
                        </terms>
                    </condition>
                </transition>
                <transition>
                    <target>Z1b</target>
                    <comment>Übergang zu Fall 2</comment>
                    <condition>
                        <name>B1b</name>
                        <terms>
                            <operation>Module.filled(N, W)</operation>
                        </terms>
                    </condition>
                </transition>
                <transition>
                    <target>Z1c</target>
                    <comment>Übergang zu Fall 3</comment>
                    <condition>
                        <name>B1c</name>
                        <terms>
                            <operation>Module.filled(N, Y)</operation>
                        </terms>
                    </condition>
                </transition>
            </transitions>
        </state>
        <state>
            <name>Z1a</name>
            <description>N berechnet</description>
            <comment>Fall 1: Y und W gegeben, N gesucht</comment>
            <importance>HIGH</importance>
            <type>STATE</type>
            <action>
                <operation>N = Y * W</operation>
            </action>
            <!--Kein Übergang (Endzustand)-->
        </state>
        <state>
            <name>Z1b</name>
            <description>Y berechnet</description>
            <comment>Fall 2: N und W gegeben, Y gesucht</comment>
            <importance>HIGH</importance>
            <type>STATE</type>
            <action>
                <operation>Y = N / W</operation>
            </action>
            <!--Kein Übergang (Endzustand)-->
        </state>
        <state>
            <name>Z1c</name>
            <description>W berechnet</description>
            <comment>Fall 3: N und Y gegeben, W gesucht</comment>
            <importance>HIGH</importance>
            <type>STATE</type>
            <action>
                <operation>W = N / Y</operation>
            </action>
            <!--Kein Übergang (Endzustand)-->
        </state>
    </states>
</module>