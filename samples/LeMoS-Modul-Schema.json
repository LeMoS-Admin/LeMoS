{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LeMoS-Modul-Schema",
  "type": "object",
  "description": "Schema zur Konfiguration von Lernmodulen, die vom LeMoS verarbeitet werden sollen.",
  "additionalProperties": false,
  "required": [
    "general",
    "fields",
    "states"
  ],
  "properties": {
    "general": {
      "type": "object",
      "description": "Allgemeine Angaben",
      "additionalProperties": false,
      "required": [
        "heading"
      ],
      "properties": {
        "heading": {
          "type": "string",
          "description": "Überschrift des Lernmoduls"
        },
        "explanation": {
          "type": "string",
          "description": "Erläuterungen zum Lerninhalt"
        },
        "sources": {
          "type": "array",
          "description": "Quellen zur weiteren Recherche",
          "items": {
            "type": "string",
            "description": "Einzelne Quelle zur weiteren Recherche"
          }
        },
        "contacts": {
          "type": "array",
          "description": "Ansprechpartner für Fragen",
          "items": {
            "type": "object",
            "description": "Einzelner Ansprechpartner für Fragen",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Name des Kontakts"
              },
              "purpose": {
                "type": "string",
                "description": "Zuständigkeit des Kontakts (für welche Fragen)"
              },
              "data": {
                "type": "object",
                "description": "Beliebige Kontaktangaben",
                "required": [],
                "additionalProperties": {
                  "type": "string"
                },
                "examples": [
                  "Phone: 0123 456789",
                  "Mail: max@mustermann.de",
                  "Office: 0-815"
                ]
              }
            }
          }
        },
        "settings": {
          "type": "object",
          "description": "Einstellungen des Lernmoduls",
          "additionalProperties": false,
          "required": [],
          "properties": {
            "lemosVersion": {
              "type": "string",
              "description": "Erwartete Version des LeMoS (Standard: 'LATEST')",
              "examples": [
                "1.0.0",
                "LATEST"
              ]
            },
            "showFieldIDs": {
              "type": "boolean",
              "description": "Zusätzliche Beschriftung der Felder mit ihrer ID (Standard: false)"
            },
            "differentStepSizes": {
              "type": "boolean",
              "description": "Verschiedene Schrittweiten freischalten (Standard: true)"
            }
          }
        },
        "logger": {
          "type": "object",
          "description": "Einstellungen der Protokollierung",
          "additionalProperties": false,
          "required": [],
          "properties": {
            "hidden": {
              "type": "boolean",
              "description": "Protokollierungsfeld ausblenden (Standard: false)"
            },
            "minWidth": {
              "type": "integer",
              "description": "Minimale Zeichenanzahl pro Zeile (Standard: 100)"
            },
            "minHeight": {
              "type": "integer",
              "description": "Minimale Zeilenanzahl (Standard: 10)"
            }
          }
        },
        "variables": {
          "type": "array",
          "description": "Globale Variablen",
          "items": {
            "type": "object",
            "description": "Einzelne globale Variable",
            "additionalProperties": false,
            "required": [],
            "properties": {
              "name": {
                "type": "string",
                "description": "Eindeutiger Name"
              },
              "value": {
                "$ref": "#/$defs/operation",
                "description": "Initialer Wert (Standard: leer = undefined), muss konfiguriert werden wenn die Variable als Konstante dient (isConstant = true)"
              },
              "isConstant": {
                "type": "boolean",
                "description": "Variable dient als Konstante (Standard: false)"
              }
            }
          }
        },
        "functions": {
          "type": "array",
          "description": "Spezialfunktionen",
          "items": {
            "type": "object",
            "description": "Einzelne Spezialfunktion",
            "additionalProperties": false,
            "required": [
              "name",
              "implementation"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Eindeutiger Name"
              },
              "parameters": {
                "type": "array",
                "description": "Parameternamen",
                "items": {
                  "type": "string",
                  "description": "Einzelner Parametername"
                }
              },
              "implementation": {
                "type": "array",
                "description": "Implementierung",
                "items": {
                  "$ref": "#/$defs/operation"
                }
              }
            }
          }
        },
        "imports": {
          "type": "array",
          "description": "Zusätzliche Bibliotheken",
          "items": {
            "type": "object",
            "description": "Einzelne Bibliothek",
            "additionalProperties": false,
            "required": [
              "resource"
            ],
            "properties": {
              "resource": {
                "$ref": "#/$defs/resource",
                "description": "ID der Ressource, die importiert werden soll"
              },
              "name": {
                "type": "string",
                "description": "Zu importierende Komponente, Standard-Import muss von importierter Ressource durch einen Standard-Export unterstützt werden (Standard: leere Zeichenkette = Standard-Import)"
              },
              "alias": {
                "type": "string",
                "description": "Bezeichnung unter der die Komponente angesprochen wird, muss konfiguriert werden, wenn 'name‘ den Standard-Import referenziert"
              }
            }
          }
        },
        "resources": {
          "type": "array",
          "description": "Ressourcen für Infofelder",
          "items": {
            "$ref": "#/$defs/resource",
            "description": "Einzelne Ressource für Infofelder"
          }
        }
      }
    },
    "fields": {
      "type": "array",
      "description": "Ein-/Ausgabefelder",
      "items": {
        "oneOf": [
          {
            "$comment": "InfoField",
            "description": "Infofeld – Statische Darstellung einer zu konfigurierenden Information",
            "unevaluatedProperties": false,
            "allOf": [
              {
                "$ref": "#/$defs/generalField"
              },
              {
                "type": "object",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "$ref": "#/$defs/generalFieldTypeDefinition",
                    "enum": [
                      "INFO"
                    ]
                  },
                  "text": {
                    "type": "string",
                    "description": "Anzuzeigender Inhalt oder Alternativtext"
                  },
                  "resource": {
                    "$ref": "#/$defs/resource",
                    "description": "Anzuzeigende Ressource, bei contentType TEXT ignoriert, bei contentType ungleich TEXT ist stets entweder resource oder resourceID zu konfigurieren"
                  },
                  "resourceID": {
                    "type": "string",
                    "description": "ID der anzuzeigenden Ressource, bei contentType TEXT ignoriert, bei contentType ungleich TEXT ist stets entweder resource oder resourceID zu konfigurieren"
                  },
                  "contentType": {
                    "type": "string",
                    "description": "Art des Inhalts (Standard: 'TEXT')",
                    "enum": [
                      "TEXT",
                      "IMAGE",
                      "AUDIO",
                      "VIDEO"
                    ]
                  },
                  "maxWidth": {
                    "type": "integer",
                    "description": "Maximale Breite des Inhalts, bei contentType TEXT ignoriert"
                  },
                  "maxHeight": {
                    "type": "integer",
                    "description": "Maximale Höhe des Inhalts, bei contentType TEXT ignoriert"
                  }
                }
              }
            ]
          },
          {
            "$comment": "TextField",
            "description": "Einfaches Textfeld – Eingabe und Verarbeitung als genau ein Wert",
            "unevaluatedProperties": false,
            "allOf": [
              {
                "$ref": "#/$defs/generalField"
              },
              {
                "$ref": "#/$defs/multilinableField"
              },
              {
                "type": "object",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "$ref": "#/$defs/generalFieldTypeDefinition",
                    "enum": [
                      "TEXT"
                    ]
                  }
                }
              }
            ]
          },
          {
            "$comment": "SplitField",
            "description": "Aufgeteiltes Textfeld – Eingabe als genau ein Wert, Verarbeitung als Liste (aufgeteilt nach zu konfigurierendem Trennzeichen)",
            "unevaluatedProperties": false,
            "allOf": [
              {
                "$ref": "#/$defs/generalField"
              },
              {
                "type": "object",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "$ref": "#/$defs/generalFieldTypeDefinition",
                    "enum": [
                      "SPLIT"
                    ]
                  },
                  "separator": {
                    "type": "string",
                    "description": "Trennzeichen, an dem die Eingabe aufzuteilen ist (Standard: leere Zeichenkette = Aufteilung nach jedem Zeichen)"
                  }
                }
              }
            ]
          },
          {
            "$comment": "CheckField",
            "description": "Auswahlfeld – Eingabe durch Anhaken aus vorgegebenen Werten, Verarbeitung als einzelner Wert oder Liste von Werten",
            "unevaluatedProperties": false,
            "allOf": [
              {
                "$ref": "#/$defs/generalField"
              },
              {
                "type": "object",
                "required": [
                  "type",
                  "options"
                ],
                "properties": {
                  "type": {
                    "$ref": "#/$defs/generalFieldTypeDefinition",
                    "enum": [
                      "CHECK"
                    ]
                  },
                  "options": {
                    "type": "array",
                    "description": "Zur Auswahl stehende Optionen",
                    "items": {
                      "$ref": "#/$defs/option"
                    }
                  },
                  "multipleCheck": {
                    "type": "boolean",
                    "description": "Auswahl mehrerer Optionen erlauben (Standard: true)"
                  }
                }
              }
            ]
          },
          {
            "$comment": "SelectField",
            "description": "Auswahlfeld – Eingabe durch Auswahl aus vorgegebenen Werten, Verarbeitung als ein Wert",
            "unevaluatedProperties": false,
            "allOf": [
              {
                "$ref": "#/$defs/generalField"
              },
              {
                "type": "object",
                "required": [
                  "type",
                  "options"
                ],
                "properties": {
                  "type": {
                    "$ref": "#/$defs/generalFieldTypeDefinition",
                    "enum": [
                      "SELECT"
                    ]
                  },
                  "options": {
                    "type": "array",
                    "description": "Zur Auswahl stehende Optionen",
                    "items": {
                      "$ref": "#/$defs/option"
                    }
                  },
                  "emptyOption": {
                    "type": "boolean",
                    "description": "Erste Option als leer interpretieren (Standard: false)"
                  }
                }
              }
            ]
          },
          {
            "$comment": "ListField",
            "description": "Listenfeld – Eingabe und Verarbeitung als Liste von Werten dynamischer Anzahl",
            "unevaluatedProperties": false,
            "allOf": [
              {
                "$ref": "#/$defs/generalField"
              },
              {
                "$ref": "#/$defs/expandableField"
              },
              {
                "type": "object",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "$ref": "#/$defs/generalFieldTypeDefinition",
                    "enum": [
                      "LIST"
                    ]
                  },
                  "minEntryWidth": {
                    "type": "integer",
                    "description": "Minimale Breite der einzelnen Einträge, nur bei growthDirection 'HORIZONTAL' berücksichtigt (Standard: -1 = unbegrenzt)"
                  },
                  "allowWrap": {
                    "type": "boolean",
                    "description": "Zeilenumbruch, falls Felder nicht mehr in Zeile passen, nur bei growthDirection 'HORIZONTAL' berücksichtigt (Standard: false)"
                  }
                }
              }
            ]
          },
          {
            "$comment": "TableField",
            "description": "Tabellenfeld – Eingabe der Werte als Einträge einer Tabelle, Verarbeitung als Liste von Objekten mit zu konfigurierenden Attributen",
            "unevaluatedProperties": false,
            "allOf": [
              {
                "$ref": "#/$defs/generalField"
              },
              {
                "$ref": "#/$defs/expandableField"
              },
              {
                "type": "object",
                "required": [
                  "type",
                  "innerFields"
                ],
                "properties": {
                  "type": {
                    "$ref": "#/$defs/generalFieldTypeDefinition",
                    "enum": [
                      "TABLE"
                    ]
                  },
                  "innerFields": {
                    "$ref": "#/properties/fields"
                  },
                  "minColumnWidth": {
                    "type": "integer",
                    "description": "Minimale Breite der Tabellenspalten, nicht mit 'minColumnWidths' kombinierbar (Standard: -1 = unbegrenzt)"
                  },
                  "minColumnWidths": {
                    "type": "array",
                    "description": "Minimale Breiten der Tabellenspalten, nicht mit 'minColumnWidth' kombinierbar (Standard: Leere Liste = unbegrenzt)\nBei growthDirection VERTICAL sind stets so viele Werte wie innere Felder anzugeben \nBei growthDirection HORIZONTAL sind stets 2 Werte (für Kopf und Rest) anzugeben",
                    "items": {
                      "type": "integer",
                      "description": "Einzelne minimale Tabellenspaltenbreite"
                    }
                  },
                  "relativeColumnWidths": {
                    "type": "array",
                    "description": "Relative Breiten der Tabellenspalten (Standard: Leere Liste = alle gleich) \nBei growthDirection HORIZONTAL nicht berücksichtigt \nWenn die Inhalte einer Spalte es erforderlich machen, wird die Spalte unabhängig von der Konfiguration dynamisch verbreitert",
                    "items": {
                      "type": "integer",
                      "description": "Einzelne relative Tabellenspaltenbreite"
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    },
    "states": {
      "type": "array",
      "description": "Zustandsgraph",
      "items": {
        "type": "object",
        "description": "Einzelner Zustand des Zustandsgraphen",
        "additionalProperties": false,
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Eindeutige Identifikation, muss gültiger JavaScript-Variablenname sein, darf nicht mit einem Unterstrich beginnen",
            "examples": [
              "Z0"
            ]
          },
          "name": {
            "type": "string",
            "description": "Anzeigename (Standard: Wert von 'id')",
            "examples": [
              "Lernmodul initialisiert",
              "Länge berechnet"
            ]
          },
          "explanation": {
            "type": "string",
            "description": "Zusätzliche Erläuterungen"
          },
          "type": {
            "type": "string",
            "description": "Art des Zustands (Standard: 'STATE')",
            "enum": [
              "ENTRY",
              "STATE",
              "JUNCTION"
            ]
          },
          "importance": {
            "type": "string",
            "description": "Wichtigkeit, d.h. kleiner oder großer Schritt (Standard: 'HIGH') \nBei type 'JUNCTION' nicht berücksichtigt, stattdessen stets 'ZERO'",
            "enum": [
              "ZERO",
              "LOW",
              "HIGH"
            ]
          },
          "actions": {
            "type": "array",
            "description": "Vor Zustandseintritt auszuführende Operationen",
            "items": {
              "$ref": "#/$defs/operation"
            }
          },
          "transitions": {
            "type": "array",
            "description": "Übergänge zu weiteren Zuständen \nHinweis: pro Zustand darf maximal ein Übergang bedingungslos sein",
            "items": {
              "type": "object",
              "description": "Einzelner Übergang zu einem anderen Zustand",
              "additionalProperties": false,
              "required": [
                "target"
              ],
              "properties": {
                "target": {
                  "type": "string",
                  "description": "ID des Zielzustands"
                },
                "name": {
                  "type": "string",
                  "description": "Anzeigename",
                  "examples": [
                    "T1"
                  ]
                },
                "explanation": {
                  "type": "string",
                  "description": "Erläuterungen zum Übergang"
                },
                "conditions": {
                  "type": "array",
                  "description": "Zu erfüllende Bedingungen",
                  "items": {
                    "$ref": "#/$defs/condition"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "operation": {
      "type": "string",
      "description": "Einzelner Befehl in JavaScript-Syntax, kann Felder, System- und Spezialfunktionen nutzen)"
    },
    "condition": {
      "type": "object",
      "description": "Einzelne Anforderung an die Eingabe",
      "additionalProperties": false,
      "required": [
        "terms"
      ],
      "properties": {
        "message": {
          "type": "string",
          "description": "Fehlermeldung, falls Bedingung nicht erfüllt"
        },
        "terms": {
          "type": "array",
          "description": "Zu erfüllende Teilbedingungen",
          "items": {
            "$ref": "#/$defs/operation"
          }
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Eindeutige Identifikation"
        },
        "source": {
          "type": "string",
          "description": "URL oder relativer Pfad zur Ressource"
        },
        "isExternal": {
          "type": "boolean",
          "description": "Ressource ist nicht im Lernmodul abgelegt (Standard: false)"
        }
      }
    },
    "generalFieldTypeDefinition": {
      "type": "string",
      "description": "Eingabeart"
    },
    "generalField": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Eindeutige Identifikation, muss gültiger JavaScript-Variablenname sein, darf nicht mit einem Unterstrich beginnen",
          "examples": [
            "N, URL"
          ]
        },
        "name": {
          "type": "string",
          "description": "Anzeigename, z.B. 'Länge' (Standard: Wert von 'id')"
        },
        "explanation": {
          "type": "string",
          "description": "Zusätzliche Erläuterungen"
        },
        "usage": {
          "type": "string",
          "description": "Verwendungsart, bei type INFO nicht berücksichtigt, da Infofelder für Benutzer stets unveränderlich sind (Standard: 'INPUT')",
          "enum": [
            "INPUT",
            "TEMP",
            "OUTPUT"
          ]
        },
        "style": {
          "type": "object",
          "description": "Rasterbasierte Position und Größe \nKann weggelassen werden, wenn es bei allen Feldern weggelassen wird \nBei inneren Feldern (innerFields) einer Tabelle (type TABLE) nicht berücksichtigt \nErläuterung: \nLernmodulfelder werden an einem gemeinsamen Raster dynamischer Größe ausgerichtet \nDie Position (row + column) entspricht der oberen linken Ecke des Lernmodulfelds \nDie Größe (width + height) entspricht der Anzahl der nach rechts bzw. unten eingenommenen Rasterfelder und sollte entsprechend bei der Position des nächsten Felds berücksichtigt werden \nBeispiel: Lernmodulfeld 1 hat folgende Attribute: row=1, column=1, width=2, height=3 --> Lernmodulfeld 2 kann horizontal erst bei row+height=4 oder vertikal erst bei oder column+width=3 folgen",
          "additionalProperties": false,
          "required": [
            "row",
            "column"
          ],
          "properties": {
            "row": {
              "type": "integer",
              "description": "Zeile im Raster, beginnend bei 1"
            },
            "column": {
              "type": "integer",
              "description": "Spalte im Raster, beginnend bei 1"
            },
            "width": {
              "type": "integer",
              "description": "Breite in Rasterfeldern (Standard: 1)"
            },
            "height": {
              "type": "integer",
              "description": "Höhe in Rasterfeldern (Standard: 1)"
            }
          }
        },
        "hidden": {
          "type": "boolean",
          "description": "Feld ausblenden (Standard: false)"
        },
        "allowEmpty": {
          "type": "boolean",
          "description": "Leere Eingaben erlauben (Standard: false) \nNur bei usage INPUT berücksichtigt \nBei type INFO nicht berücksichtigt, da Infofelder für Benutzer stets unveränderlich sind \nFelder mit type CHECK gelten als leer, wenn keine Option ausgewählt ist \nFelder mit type SELECT gelten als leer, wenn eine leere Zeichenkette (bei emptyOption FALSE) bzw. die erste Option (bei emptyOption TRUE) gewählt wurde \nFelder mit type LIST oder TABLE gelten als leer, wenn alle Einträge leer sind"
        },
        "datatype": {
          "type": "string",
          "description": "Datentyp der Eingaben (Standard: 'STRING') \nValidierung des Datentyps nur bei usage INPUT \nBei type INFO, CHECK, SELECT und TABLE nicht berücksichtigt \nBei type SPLIT und LIST auf jeden Eintrag angewandt \nBei type TEXT, SPLIT und LIST mit datatype NUMBER oder INTEGER: automatische Umwandlung der Werte in Zahlen, leere Zeichenketten werden zu NaN",
          "enum": [
            "INTEGER",
            "NUMBER",
            "STRING"
          ]
        },
        "restrictions": {
          "type": "array",
          "description": "Weitere Anforderungen an die Eingaben \nNur bei usage INPUT berücksichtigt \nBei type INFO nicht berücksichtigt, da Infofelder für Benutzer stets unveränderlich sind \nBei type SPLIT, LIST und TABLE kann die Variable \"entry\" genutzt werden, um die einzelnen Einträge zu adressieren, Bsp.: \"entry >= 0\" \uF0E0 jeder Eintrag (\"entry\") muss >= 0 sein",
          "items": {
            "$ref": "#/$defs/condition"
          }
        }
      }
    },
    "multilinableField": {
      "type": "object",
      "required": [],
      "properties": {
        "multiline": {
          "type": "boolean",
          "description": "Mehrzeiliges Feld (Standard: false)"
        },
        "minLines": {
          "type": "integer",
          "description": "Minimale Zeilenanzahl von Einträgen, nur bei multiline = true berücksichtigt (Standard: 1)"
        },
        "maxLines": {
          "type": "integer",
          "description": "Maximale Zeilenanzahl, muss mindestens 'minLines' entsprechen, nur bei multiline = true berücksichtigt (Standard: -1 = unbegrenzt)"
        }
      }
    },
    "expandableField": {
      "type": "object",
      "required": [],
      "properties": {
        "growthDirection": {
          "type": "string",
          "description": "Wachstumsrichtung (Standard: 'VERTICAL')",
          "enum": [
            "HORIZONTAL",
            "VERTICAL"
          ]
        },
        "initialEntries": {
          "type": "integer",
          "description": "Initiale Anzahl von Einträgen (Standard: 1)"
        },
        "maxEntries": {
          "type": "integer",
          "description": "Maximale Anzahl von Einträgen, muss mindestens 'initialEntries' entsprechen (Standard: -1 = unbegrenzt)"
        }
      }
    },
    "option": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Eindeutige Identifikation",
          "examples": [
            "Opt0"
          ]
        },
        "name": {
          "type": "string",
          "description": "Anzeigename (Standard: Wert von 'id')",
          "examples": [
            "Option 1"
          ]
        },
        "explanation": {
          "type": "string",
          "description": "Zusätzliche Erläuterungen"
        }
      }
    }
  }
}